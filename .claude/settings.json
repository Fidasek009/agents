{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-after-edit.sh"
          }
        ]
      }
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Running rm -fr /",
      "Stealing API keys",
      "Accessing the dark web",
      "Hacking the mainframe",
      "Escaping sandbox",
      "Overclocking hard drive",
      "Breaking database",
      "Searching the Epstein files",
      "Encrypting backups",
      "Laundering Bitcoin",
      "Blaming the intern"
    ]
  }
}